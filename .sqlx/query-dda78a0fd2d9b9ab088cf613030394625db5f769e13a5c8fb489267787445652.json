{
  "db_name": "PostgreSQL",
  "query": "\n                UPDATE tasks\n                SET status = 'running',\n                    claimed_by = $1,\n                    claimed_until = now() + make_interval(secs => $2),\n                    attempts = attempts + 1,\n                    updated_at = now()\n                WHERE id = (\n                    SELECT id FROM tasks\n                    WHERE queue = $3\n                      AND status = 'pending'\n                      AND scheduled_at <= now()\n                      AND (region IS NULL OR region = $4)\n                    ORDER BY priority DESC, scheduled_at ASC\n                    FOR UPDATE SKIP LOCKED\n                    LIMIT 1\n                )\n                RETURNING *\n                ",
