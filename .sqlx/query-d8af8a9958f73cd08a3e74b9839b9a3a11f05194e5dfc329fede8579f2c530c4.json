{
  "db_name": "PostgreSQL",
  "query": "\n            UPDATE tasks\n            SET status = CASE\n                    WHEN attempts < max_attempts THEN 'pending'\n                    ELSE 'failed'\n                END,\n                claimed_by = CASE\n                    WHEN attempts < max_attempts THEN NULL\n                    ELSE claimed_by\n                END,\n                claimed_until = CASE\n                    WHEN attempts < max_attempts THEN NULL\n                    ELSE claimed_until\n                END,\n                last_error = $2,\n                scheduled_at = CASE\n                    WHEN attempts < max_attempts\n                    THEN now() + make_interval(secs =>\n                        LEAST($3 * power(2, attempts - 1), $4)\n                        * (0.75 + random() * 0.5))\n                    ELSE scheduled_at\n                END,\n                updated_at = now()\n            WHERE id = $1\n              AND status = 'running'\n            RETURNING *\n            ",
