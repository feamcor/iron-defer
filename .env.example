# iron-defer environment configuration template.
# Copy to .env and fill in real values. .env is gitignored.
#
# Precedence (ADR-0003): defaults < config.toml < .env < env vars < CLI flags.
# Environment variables use IRON_DEFER__ prefix with __ separator for nesting.

# Database (also accepted as DATABASE_URL for compatibility)
IRON_DEFER__DATABASE__URL=postgres://iron_defer:iron_defer@localhost:5432/iron_defer
# Maximum: 100 (FR41)
IRON_DEFER__DATABASE__MAX_CONNECTIONS=10
# IRON_DEFER__DATABASE__UNLOGGED_TABLES=false
# IRON_DEFER__DATABASE__AUDIT_LOG=false

# HTTP server
IRON_DEFER__SERVER__PORT=8080

# Worker pool
IRON_DEFER__WORKER__CONCURRENCY=4
IRON_DEFER__WORKER__LOG_PAYLOAD=false
# IRON_DEFER__WORKER__LEASE_DURATION=5m
# IRON_DEFER__WORKER__POLL_INTERVAL=500ms
# IRON_DEFER__WORKER__SWEEPER_INTERVAL=1m
# IRON_DEFER__WORKER__BASE_DELAY=5s
# IRON_DEFER__WORKER__MAX_DELAY=30m
# IRON_DEFER__WORKER__SHUTDOWN_TIMEOUT=30s

# Observability (empty = disabled)
IRON_DEFER__OBSERVABILITY__OTLP_ENDPOINT=
IRON_DEFER__OBSERVABILITY__PROMETHEUS_PATH=/metrics

# Optional: select config overlay (config.{profile}.toml)
# IRON_DEFER_PROFILE=local

# Testing: set to 1 to fail (instead of skip) when Docker is unavailable
# IRON_DEFER_REQUIRE_DB=1
